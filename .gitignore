# 如何直接从git删除 git rm -r --cached 文件路径/文件夹/后缀

# 忽略 __pycache__ 目录下的所有内容
__pycache__/

# 忽略pycharm文件
.idea/

# 忽略所有 .pyc 文件 即python缓存
*.pyc

# 忽略虚拟环境
.venv/

# 忽略本地数据库连接配置
image_resource_db.local.json

# 忽略本地分发产物
dist/

# 忽略本地更新与备份运行数据
backups/
update_cache/

# 忽略settings.json 用户配置文件
config/settings.json

# 忽略用户自截图文件
config/cus_images/用户自截/

# 忽略用户 开/删物品 额外文件
config/cus_images/背包_装备_需使用的/任意通用包裹.png
config/cus_images/背包_装备_需使用的/美味酬劳.png
config/cus_images/背包_装备_需使用的/火山酬劳.png
config/cus_images/背包_装备_需使用的/浮空酬劳.png
config/cus_images/背包_装备_需使用的/星际酬劳.png

# 忽略运行产生的文件 主要是日志
logs/

# 忽略 main.spec
main.spec

# 忽略其他开发资源
resource_other/

# 忽略各测试 output 目录中的本地生成物，不影响脚本、文档和测试夹具
test/**/output/**/*.png
test/**/output/**/*.jpg
test/**/output/**/*.jpeg
test/**/output/**/*.bmp
test/**/output/**/*.gif
test/**/output/**/*.webp
test/**/output/**/*.csv
test/**/output/**/*.log
test/**/output/**/*.npy
