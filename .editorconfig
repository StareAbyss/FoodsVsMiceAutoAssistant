# EditorConfig keeps indentation, newline, and encoding rules stable across editors.
# See: https://editorconfig.org/
root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{md,txt,json,yml,yaml,toml}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
